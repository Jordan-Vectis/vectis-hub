generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Roles are stored as free-form strings on User.role. "ADMIN" is the only
// hardcoded role — every other role comes from the RoleDefault table.
// Admins manage roles via /admin/role-defaults (add, edit permissions, delete).

enum SubmissionChannel {
  EMAIL
  WEB_FORM
  PHONE
  WALK_IN
}

enum SubmissionStatus {
  PENDING_ASSIGNMENT
  PENDING_VALUATION
  VALUATION_COMPLETE
  PENDING_CUSTOMER_DECISION
  APPROVED
  DECLINED
  FOLLOW_UP
  COLLECTION_PENDING
  ARRIVED
  COMPLETED
}

enum LogisticsType {
  SENT_IN
  COLLECTION
}

model User {
  id             String      @id @default(cuid())
  name           String
  email          String      @unique
  username       String?     @unique
  password       String
  role           String      @default("COLLECTIONS")  // "ADMIN" or any custom role name from RoleDefault
  allowedApps    String[]    @default([])
  appPermissions Json?
  showScanTimer  Boolean     @default(true)
  timerYellowMins Int       @default(4)
  timerRedMins    Int       @default(10)
  isITStaff      Boolean     @default(false)  // can be assigned IT Job Board jobs
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  assignedSubmissions Submission[] @relation("AssignedCataloguer")
  createdSubmissions  Submission[] @relation("CreatedBy")
  valuations          Valuation[]
  contactLogs         ContactLog[]
  bcToken             BCToken?
  devices             Device[]
}

model BCToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  submissions Submission[]
}

model Contact {
  id           String   @id
  salutation   String?
  name         String
  email        String?
  phone        String?
  addressLine1 String?
  addressLine2 String?
  postcode     String?
  notes        String?
  isSeller     Boolean  @default(false)
  isBuyer      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  receipts        WarehouseReceipt[] @relation("ContactReceipts")
  submissions     Submission[]       @relation("ContactSubmissions")
  customerAccount CustomerAccount?
}

model CustomerAccount {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  firstName    String
  lastName     String
  phone        String?
  sessionToken String?  @unique
  contactId    String?  @unique
  contact      Contact? @relation(fields: [contactId], references: [id])
  bidderRegistrations BidderRegistration[]
  commissionBids      CommissionBid[]
  parcels             Parcel[]

  // Shipping address
  shippingLine1   String?
  shippingLine2   String?
  shippingCity    String?
  shippingCounty  String?
  shippingPostcode String?

  // Billing address
  billingLine1    String?
  billingLine2    String?
  billingCity     String?
  billingCounty   String?
  billingPostcode String?
  billingSameAsShipping Boolean @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Submission {
  id             String            @id @default(cuid())
  reference      String            @unique @default(cuid())
  channel        SubmissionChannel
  status         SubmissionStatus  @default(PENDING_ASSIGNMENT)
  notes            String?
  followUpCount    Int               @default(0)
  lastFollowUpAt   DateTime?
  photoUploadToken     String?  @unique
  valuationToken       String?  @unique
  valuationNotes       String?
  valuationSubmittedAt DateTime?
  valuationSentTo      String?
  needsFollowUp        Boolean  @default(false)

  contactId    String
  contact      Contact     @relation("ContactSubmissions", fields: [contactId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  cataloguerId String?
  cataloguer   User?       @relation("AssignedCataloguer", fields: [cataloguerId], references: [id])
  createdById  String
  createdBy    User        @relation("CreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items       Item[]
  contactLogs ContactLog[]
  logistics   Logistics?
  staffNotes  SubmissionNote[]
}

// Internal staff notes on a submission — a running, timestamped log (not the
// customer's submission `notes`, and separate from the customer ContactLog).
model SubmissionNote {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  body         String     @db.Text
  authorId     String?
  authorName   String
  createdAt    DateTime   @default(now())

  @@index([submissionId])
}

model Item {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageUrls   String[]
  externalEstimate    Int?
  externalNotes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  valuation    Valuation?
}

model Valuation {
  id             String   @id @default(cuid())
  estimatedValue Float
  comments       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  itemId       String @unique
  item         Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  cataloguerId String
  cataloguer   User   @relation(fields: [cataloguerId], references: [id])
}

model ContactLog {
  id      String   @id @default(cuid())
  method  String
  notes   String?
  outcome String?
  isFollowUp Boolean @default(false)
  createdAt DateTime @default(now())

  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id])
}

model AuctionRun {
  id        String       @id @default(cuid())
  code      String       @unique
  preset    String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  lots      AuctionLot[]
}

model AuctionLot {
  id                  String     @id @default(cuid())
  lot                 String
  description         String     @db.Text
  estimate            String
  originalDescription String?    @db.Text
  keyPoints           String?    @db.Text
  missing             String?    @db.Text
  added               String?    @db.Text
  createdAt           DateTime   @default(now())

  runId String
  run   AuctionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model AiPreset {
  key         String   @id
  instruction String   @db.Text
  updatedAt   DateTime @updatedAt
}

model PipelineRun {
  id        String        @id @default(cuid())
  code      String        @unique
  preset    String        @default("")
  model     String        @default("")
  stage     String        @default("batch")  // "batch" | "doublecheck" | "kpcheck" | "complete"
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  lots      PipelineLot[]
}

model PipelineLot {
  id          String      @id @default(cuid())
  runId       String
  run         PipelineRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  lotId       String
  label       String

  // Stage 1 — Batch Run
  batchStatus  String?    // "ok" | "failed" | "skipped"
  description  String?    @db.Text   // running latest text (overwritten by DC)
  batchDesc    String?    @db.Text   // original raw batch text, preserved for DC before/after
  estimate     String?

  // Stage 2 — Double Check
  dcStatus       String?  // "ok" | "issues" | "error" | "skipped"
  contradictions String?  @db.Text
  unsupported    String?  @db.Text

  // Stage 3 — Key Points Check
  kpStatus   String?      // "ok" | "fixed" | "error" | "skipped"
  revised    String?      @db.Text
  kpMissing  String?      @db.Text
  kpAdded    String?      @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([runId, lotId])
}

model Logistics {
  id      String        @id @default(cuid())
  type    LogisticsType
  arrived Boolean       @default(false)
  arrivedAt DateTime?

  collectionAddress String?
  collectionName    String?
  collectionPhone   String?
  collectionEmail   String?
  collectionNotes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissionId String     @unique
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model CatalogueAuction {
  id          String         @id @default(cuid())
  code        String         @unique
  name        String
  auctionDate DateTime?
  auctionType String         @default("GENERAL")
  eventName   String?
  locked      Boolean        @default(false)
  finished    Boolean        @default(false)
  complete    Boolean        @default(false)
  catalogued  Boolean        @default(false)
  addedToBC   Boolean        @default(false)
  photography Boolean        @default(false)
  aiRan       Boolean        @default(false)
  published   Boolean        @default(false)
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  lots        CatalogueLot[]
  photoSessions CataloguePhotoSession[]
  timingLogs  CatalogueTimingLog[]
  idleLogs    IdleLog[]
  liveAuction LiveAuction?
  bidderRegistrations BidderRegistration[]
  webDescriptions WebDescription[]
}

model BidderRegistration {
  id                String           @id @default(cuid())
  auctionId         String
  auction           CatalogueAuction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  customerAccountId String
  customerAccount   CustomerAccount  @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  contactId         String?          // C number e.g. C000001
  acceptedTerms     Boolean          @default(true)
  registeredAt      DateTime         @default(now())

  @@unique([auctionId, customerAccountId])
}

model LiveAuction {
  id              String           @id @default(cuid())
  auctionId       String           @unique
  auction         CatalogueAuction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  status          String           @default("PENDING") // PENDING | ACTIVE | PAUSED | COMPLETE
  currentLotIndex Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model CatalogueLot {
  id           String           @id @default(cuid())
  title        String
  keyPoints    String           @db.Text @default("")
  description  String           @db.Text @default("")
  barcode      String?
  estimateLow    Int?
  estimateHigh   Int?
  aiEstimateLow  Int?
  aiEstimateHigh Int?
  startingBid  Int?
  reserve      Int?
  currentBid   Int?
  hammerPrice  Int?
  condition    String?
  vendor          String?
  tote            String?
  receipt         String?
  receiptUniqueId String?
  category     String?
  subCategory  String?
  brand        String?
  notes        String?
  extraDetails String?  @db.Text
  imageUrls    String[]         @default([])
  status        String           @default("ENTERED")
  aiExcluded    Boolean          @default(false)  // Lot description was typed manually — exclude from all AI runs
  aiUpgraded    Boolean          @default(false)
  addedToBC     Boolean          @default(false)  // Manually ticked by cataloguers once a lot has been pushed into Business Central
  reviewFlag      String?        @db.Text         // set from the Review tab when a checker spots an error — the reason text
  reviewFlaggedBy String?
  reviewFlaggedAt DateTime?
  aiFlagNote      String?        @db.Text         // AI-flagged potential cataloguer mistake from the batch pipeline run
  createdByName String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  auctionId    String
  auction      CatalogueAuction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  commissionBids CommissionBid[]
  parcelLots   ParcelLot[]
}

model CommissionBid {
  id                String          @id @default(cuid())
  lotId             String
  lot               CatalogueLot    @relation(fields: [lotId], references: [id], onDelete: Cascade)
  customerAccountId String
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  maxBid            Int
  contactId         String?
  notes             String?
  placedAt          DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([lotId, customerAccountId])
}

model IdleLog {
  id             String           @id @default(cuid())
  userId         String
  userName       String
  auctionId      String
  auction        CatalogueAuction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  idleStartedAt  DateTime
  idleDurationMs Int
  reason         String           // LUNCH_BREAK | LOTTING_UP | OTHER
  toteNumbers    String?
  notes          String?
  createdAt      DateTime         @default(now())
}

model CatalogueTimingLog {
  id           String           @id @default(cuid())
  auctionId    String
  auction      CatalogueAuction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  lotId        String?          // ID of the lot that was created
  userId       String           // Internal user ID
  userName     String           // Display name of cataloguer
  method       String           // "WIZARD" | "PHOTO_ONLY"
  durationMs   Int              // Total ms from barcode entry to save
  keyPointsMs  Int?             // Ms spent on the Key Points step (wizard only)
  savedAt      DateTime         @default(now())
}

model CataloguePhotoSession {
  id              String           @id @default(cuid())
  auctionId       String
  auction         CatalogueAuction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  lotBarcode      String?
  customerRef     String?
  barcodePhotoKey String?
  itemPhotoKeys   String[]         @default([])
  notes           String?
  status          String           @default("PENDING")
  createdById     String
  createdByName   String?
  createdAt       DateTime         @default(now())
}

model AppCard {
  key         String  @id
  order       Int     @default(0)
  visible     Boolean @default(true)
  pinned      Boolean @default(false)
  label       String?
  description String?
}

// Singleton (id = "global") — stores idle-timer global defaults and the
// admin-managed reasons list. Created on first GET if absent.
model IdleTimerConfig {
  id          String   @id @default("global")
  yellowMins  Int      @default(4)
  redMins     Int      @default(10)
  reasons     Json     @default("[]")   // IdleReason[]
  updatedAt   DateTime @updatedAt
}

model RoleDefault {
  role           String   @id  // "COLLECTIONS" | "CATALOGUER"
  allowedApps    String[] @default([])
  appPermissions Json?
  updatedAt      DateTime @updatedAt
}

model MarketingDraft {
  id           String   @id @default(cuid())
  title        String
  contentType  String   // "sale_highlight" | "news_story" | "email_newsletter" | "social_instagram" | etc.
  content      String   // HTML or plain text
  status       String   @default("DRAFT")  // DRAFT | APPROVED | PUBLISHED
  publishedUrl String?
  createdById  String?
  createdByName String?
  lotsSnapshot Json?    // The lots used to generate, kept for re-generation
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MarketingHashtag {
  id         String   @id @default(cuid())
  category   String   // "Diecast" | "Star Wars" | "Trains" | "General" etc.
  hashtags   String[] @default([])
  updatedAt  DateTime @updatedAt
}

model BCCatalogueDay {
  date      String                       // "YYYY-MM-DD" — marks this date was fully fetched from BC
  mode      String   @default("barcode") // "barcode" (Internal Barcode mods) | "uniqueid" (Auction Line UniqueID inserts)
  fetchedAt DateTime @default(now())

  @@id([date, mode])
}

model BCCatalogueEntry {
  date   String
  userId String
  mode   String @default("barcode")
  count  Int

  @@id([date, userId, mode])
  @@index([date, mode])
}

model BCPackingDay {
  date      String   @id
  fetchedAt DateTime @default(now())
}

model BCPackingEntry {
  date     String
  staff    String
  docNo    String
  lotCount Int

  @@id([date, staff, docNo])
  @@index([date])
}

model WarehouseReceipt {
  id             String   @id
  contactId      String
  contact        Contact  @relation("ContactReceipts", fields: [contactId], references: [id])
  commissionRate Float    @default(0)
  notes          String?
  status         String   @default("open")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  containers WarehouseContainer[]
}

model WarehouseContainer {
  id          String           @id
  type        String
  description String
  category    String?
  subcategory String?
  receiptId   String
  receipt     WarehouseReceipt @relation(fields: [receiptId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  movements WarehouseMovement[]
}

model WarehouseLocation {
  id        String   @id @default(cuid())
  code      String   @unique
  createdAt DateTime @default(now())

  movements WarehouseMovement[]
}

model WarehouseMovement {
  id           String             @id @default(cuid())
  containerId  String
  container    WarehouseContainer @relation(fields: [containerId], references: [id])
  locationCode String
  location     WarehouseLocation  @relation(fields: [locationCode], references: [code])
  notes        String?
  movedByName  String?
  movedAt      DateTime           @default(now())
}

model Parcel {
  id                  String           @id @default(cuid())
  reference           String           @unique @default(cuid())
  status              String           @default("PENDING") // PENDING | LABEL_CREATED | DISPATCHED | CANCELLED

  // Recipient
  recipientName       String
  recipientCompany    String?
  recipientLine1      String
  recipientLine2      String?
  recipientCity       String
  recipientCounty     String?
  recipientPostcode   String
  recipientCountry    String           @default("GB")
  recipientEmail      String?
  recipientPhone      String?

  // Package
  weightInGrams       Int              @default(500)
  packageFormat       String           @default("Parcel")
  serviceCode         String           @default("TPP48")
  specialInstructions String?
  notes               String?

  // Royal Mail Click & Drop
  rmOrderIdentifier   String?
  trackingNumber      String?
  labelPdf            String?          @db.Text
  manifestId          String?
  despatchedAt        DateTime?

  // Relations
  customerAccountId   String?
  customerAccount     CustomerAccount? @relation(fields: [customerAccountId], references: [id])
  lots                ParcelLot[]

  createdByName       String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

model ParcelLot {
  id       String       @id @default(cuid())
  parcelId String
  parcel   Parcel       @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  lotId    String
  lot      CatalogueLot @relation(fields: [lotId], references: [id])

  @@unique([parcelId, lotId])
}

model MacroFile {
  id          String   @id @default(cuid())
  name        String
  filename    String
  description String?  @db.Text
  content     Bytes
  mimeType    String   @default("text/plain")
  size        Int
  createdAt   DateTime @default(now())
}

model HeroSlide {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  title     String
  subtitle  String
  cta       String
  ctaHref   String
  imageKey  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResearchLog {
  id         String   @id @default(cuid())
  userId     String
  userName   String
  durationMs Int      // active milliseconds spent on the Research page
  startedAt  DateTime // when the session began
  savedAt    DateTime @default(now())

  @@index([userId])
  @@index([savedAt])
}

// ─── Warehouse Sync ────────────────────────────────────────────────────────────

model WarehouseItem {
  id           String  @id @default(cuid())
  uniqueId     String  @unique  // EVA_UniqueID e.g. R000006-1

  // Identity
  receiptNo    String?           // EVA_ReceiptNo
  articleNo    String?           // EVA_ArticleNo
  stockNo      String?           // EVA_StockNo
  barcode      String?           // PTE_InternalBarcode

  // Description
  description  String?           // EVA_ShortDescription
  artist       String?           // EVA_Artist
  category     String?           // EVA_ArticleCategoryCode
  subcategory  String?           // EVA_ArticleSubcategoryCode

  // Vendor
  vendorNo     String?           // EVA_VendorNo
  vendorName   String?           // EVA_VendorName
  vendorEmail  String?           // EVA_VendorEmail (auction lines)

  // Sale / Auction
  auctionCode  String?           // EVA_SalesAllocation
  auctionName  String?           // EVA_AuctionName (from Auction_Lines_Excel)
  auctionDate  String?           // EVA_AuctionDate
  lotNo        String?           // EVA_LotNo
  currentLotNo String?           // EVA_CurrentLotNo (auction lines)
  lowEstimate  Float?            // EVA_LowEstimate
  highEstimate Float?            // EVA_HighEstimate
  hammerPrice  Float?            // EVA_HammerPrice
  reservePrice Float?            // EVA_ReservePrice

  // Physical location
  location     String?           // EVA_ArticleLocationCode
  binCode      String?           // EVA_ArticleBinCode
  toteNo       String?           // EVA_ArticleToteNo
  locationScannedAt DateTime?    // from ChangeLogEntries — when location was last scanned

  // Status
  catalogued        Boolean?     // EVA_Catalogued
  cataloguedBy      String?      // EVA_CataloguedBy
  cataloguedAt      DateTime?    // EVA_CataloguedDateTime
  noOfPhotos        Int?         // EVA_NoOfPhotos
  goodsReceived     Boolean?     // EVA_GoodsReceived
  goodsReceivedDate DateTime?    // EVA_GoodsReceivedDate
  collected         Boolean?     // EVA_Collected
  withdrawLot       Boolean?     // EVA_WithdrawLot (auction lines)

  // Sync metadata
  bcModifiedAt DateTime?         // EVA_SystemModifiedAt — used for incremental sync

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([auctionCode])
  @@index([location])
  @@index([toteNo])
  @@index([barcode])
}

model WarehouseSyncLog {
  id             String    @id @default(cuid())
  source         String    // "receipt_lines" | "auction_lines" | "changelog" | "totes"
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  status         String    @default("running") // "running" | "complete" | "failed"
  itemsProcessed Int       @default(0)
  lastTimestamp  String?   // ISO string — resume point for incremental syncs
  error          String?
}

// Receipt_Totes_Excel — physical totes tracked in BC.
// Synced separately from WarehouseItem (which tracks individual items).
// A tote may be at a location even if items inside don't yet have one.
model Device {
  id           String   @id @default(cuid())
  serialNumber String   @unique
  name         String
  deviceType   String   @default("iPad")
  notes        String?
  assignedTo   User?    @relation(fields: [assignedToId], references: [id])
  assignedToId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Packing-floor staff list. Used to generate a barcode sheet that gets stuck
// up at the packing benches — each packer scans their barcode to identify
// who's doing the packing in BC.
model Packer {
  id        String   @id @default(cuid())
  name      String
  staffGroup String   @default("FULL_TIME")  // "FULL_TIME" | "AGENCY"
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  // Manually-curated alternative spellings, nicknames, initials etc. that
  // should roll up into this packer in reports. Used by the matcher as an
  // exact-match overlay before the fuzzy logic runs.
  aliases   String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([staffGroup])
}

model ClaudeMemory {
  filename  String   @id
  content   String
  updatedAt DateTime @updatedAt
}

model DocumentFolder {
  id        String           @id @default(cuid())
  name      String
  parentId  String?
  parent    DocumentFolder?  @relation("FolderChildren", fields: [parentId], references: [id])
  children  DocumentFolder[] @relation("FolderChildren")
  files     DocumentFile[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model DocumentFile {
  id           String          @id @default(cuid())
  name         String
  key          String
  size         Int
  mimeType     String
  folderId     String?
  folder       DocumentFolder? @relation(fields: [folderId], references: [id])
  uploadedBy   String
  createdAt    DateTime        @default(now())
}

// Pre-typed email reply snippets staff can copy into customer responses.
// Lives behind the IT Tools "Templates" tab.
model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  category  String   @default("GENERAL")
  body      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

// Knowledge base — staff-written solutions and how-tos that the IT Help
// chatbot searches alongside resolved tickets. Plain markdown body keeps
// editing easy; tags + category drive simple keyword matching.
model KnowledgeArticle {
  id            String   @id @default(cuid())
  title         String
  body          String                          // markdown
  tags          String[] @default([])
  category      String   @default("GENERAL")    // GENERAL | HARDWARE | SOFTWARE | NETWORK | APP | HOW_TO
  createdById   String?
  createdByName String
  updatedById   String?
  updatedByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([updatedAt])
}

// User-editable ticket categories. Pre-seeded with the original hardcoded set
// (HARDWARE, SOFTWARE, NETWORK, APP_BUG, FEATURE_REQUEST, OTHER) but admins
// can add / rename / deactivate via the Manage Categories modal on the
// tickets page. `key` is the stable identifier stored on Ticket.category;
// `label` is what staff see.
model TicketCategory {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// IT ticket system — staff log problems / feature requests, IT works through
// them. Deliberately denormalised (createdByName / assignedToName stored as
// strings) so a deleted user doesn't orphan a ticket's history.
model Ticket {
  id             String          @id @default(cuid())
  title          String
  description    String
  status         String          @default("OPEN")    // OPEN | IN_PROGRESS | AWAITING_RESPONSE | RESOLVED | CLOSED
  priority       String          @default("MEDIUM")  // LOW | MEDIUM | HIGH | URGENT
  category       String          @default("OTHER")   // HARDWARE | SOFTWARE | NETWORK | APP_BUG | FEATURE_REQUEST | OTHER
  createdById    String?
  createdByName  String
  assignedToId   String?
  assignedToName String?
  resolvedAt     DateTime?
  resolutionNote String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  comments       TicketComment[]

  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model TicketComment {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorName String
  authorId   String?
  body       String
  createdAt  DateTime @default(now())

  @@index([ticketId])
}

model WarehouseTote {
  id           String   @id @default(cuid())
  toteNo       String   @unique
  location     String?
  receiptNo    String?
  vendorNo     String?
  vendorName   String?
  status       String?
  catalogued   Boolean?
  syncedAt     DateTime @default(now())

  @@index([location])
  @@index([toteNo])
  @@index([catalogued])
}

model WebDescription {
  id          String           @id @default(cuid())
  auctionId   String
  auction     CatalogueAuction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  auctionCode String
  auctionName String
  description String           @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([auctionId])
}

model SocialPost {
  id             String    @id @default(cuid())
  platform       String    @default("FACEBOOK")   // FACEBOOK | INSTAGRAM
  status         String    @default("DRAFT")       // DRAFT | SCHEDULED | POSTED | FAILED
  copy           String    @db.Text
  imageUrl       String?
  hashtags       String?
  scheduledAt    DateTime?
  postedAt       DateTime?
  specialDateTag String?
  auctionCode    String?
  createdByName  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([scheduledAt])
}

// Models the user has disabled in the Auction AI → Models tab. Presence = disabled.
// Disabled models are hidden from all model selectors/testers.
model DisabledModel {
  modelId   String   @id
  updatedAt DateTime @updatedAt
}

// Invoice file storage — flat list backed by Cloudflare R2.
// Accessible from /admin/invoices.
model InvoiceFile {
  id         String   @id @default(cuid())
  name       String
  key        String
  size       Int
  mimeType   String
  uploadedBy String
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model SocialImage {
  id           String   @id @default(cuid())
  key          String   @unique   // R2 object key
  filename     String
  label        String?            // user-friendly name/caption
  tags         String?            // comma-separated tags
  uploadedBy   String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
}


// Lot change log — every field change made via updateLot, with old/new values.
// Used by /admin/lot-log to audit edits and track down data issues.
model CatalogueLotEvent {
  id          String   @id @default(cuid())
  lotId       String
  auctionId   String
  auctionCode String
  lotBarcode  String?
  lotTitle    String?
  field       String
  oldValue    String?
  newValue    String?
  changedBy   String
  changedAt   DateTime @default(now())

  @@index([lotId])
  @@index([auctionId])
  @@index([changedAt])
  @@index([field])
}

// IT Job Board — jobs auto-created from the IT@vectis.co.uk inbox (or added
// manually). graphMessageId holds the email Message-ID for dedupe/threading;
// threadKey (normalised subject) is the fallback reply-matching key.
model ITJob {
  id             String    @id @default(cuid())
  title          String
  body           String    @db.Text @default("")
  bodyHtml       String?   @db.Text                  // sanitised HTML of the original email (if sent)
  fromName       String?
  fromEmail      String?
  status         String    @default("NEW")   // NEW | IN_PROGRESS | WAITING | DONE
  source         String    @default("EMAIL") // EMAIL | MANUAL
  graphMessageId String?   @unique            // email Message-ID
  conversationId String?                      // Office 365 Conversation Id — precise reply matching
  threadKey      String?                      // normalised subject — reply matching fallback
  webLink        String?                      // Outlook deep link to the original email
  assignedToId   String?
  assignedToName String?
  hasNewReply    Boolean   @default(false)    // a customer reply arrived that IT hasn't seen
  dueDate        DateTime?                     // optional target date for the job (date only)
  receivedAt     DateTime?
  createdByName  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  messages       ITJobMessage[]
  attachments    ITJobAttachment[]

  @@index([status])
  @@index([receivedAt])
  @@index([threadKey])
  @@index([conversationId])
  @@index([dueDate])
}

// A message on a job — either an internal IT staff note (kind=NOTE) or an
// incoming customer email reply on the same thread (kind=REPLY).
model ITJobMessage {
  id          String   @id @default(cuid())
  jobId       String
  job         ITJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  kind        String   @default("NOTE")  // NOTE | REPLY
  authorName  String?
  authorEmail String?
  body        String   @db.Text
  bodyHtml    String?  @db.Text   // sanitised HTML of the reply (if sent)
  createdAt   DateTime @default(now())

  attachments ITJobAttachment[]

  @@index([jobId])
}

// An image attached to a job. messageId is null for the original email's
// images, or set when the image arrived on a reply (ITJobMessage). Stored in R2.
model ITJobAttachment {
  id        String        @id @default(cuid())
  jobId     String
  job       ITJob         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  messageId String?
  message   ITJobMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename  String
  mimeType  String
  size      Int
  r2Key     String
  contentId String?       // email Content-ID (set => inline image, e.g. signature; rendered in the HTML, not as a thumbnail)
  createdAt DateTime      @default(now())

  @@index([jobId])
  @@index([messageId])
}

// A saved Marketing Reports layout: an ordered list of report-section ids,
// shared across all users. One can be the default. Managed by admins.
model MarketingLayout {
  id        String   @id @default(cuid())
  name      String
  sections  String[] @default([])   // ordered report-section ids
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Shared (not per-user) — a starred report-section is pinned to the top of the
// Marketing Reports page for everyone. One row per favourited section id.
model MarketingFavourite {
  sectionId String   @id
  createdAt DateTime @default(now())
}

// ─── Accounts (monthly bookkeeping from scanned invoices/receipts) ───────────
// A month is a workspace (e.g. "April 26"); each scanned/manual document becomes
// one categorised line that exports to the April-26-style spreadsheet.
model AccountingMonth {
  id        String   @id @default(cuid())
  label     String   @unique          // e.g. "April 26"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  documents AccountingDocument[]
  statements BankStatement[]
}

model AccountingDocument {
  id         String          @id @default(cuid())
  monthId    String
  month      AccountingMonth @relation(fields: [monthId], references: [id], onDelete: Cascade)
  cardholder String                              // "B Goodall" | "J Goodall" | "James" | "Michael" | "Vectis"
  source     String          @default("SCAN")    // SCAN | MANUAL
  imageKey   String?                             // legacy single-image key (superseded by images[])
  images     String[]        @default([])         // R2 keys of every page of this document (multi-page invoices)
  supplier   String          @default("")        // description / who it was paid to
  item       String          @default("")        // item/service purchased — only if clearly stated on the doc
  website    String          @default("")        // supplier website/URL — only if shown on the doc
  docDate    DateTime?
  vatCode    Int             @default(1)          // 1 = 20% reclaimable, 2 = none/zero, 7 = personal
  gross      Float           @default(0)          // Value (inc VAT)
  vat        Float           @default(0)          // VAT amount
  net        Float           @default(0)          // gross - vat
  column     String          @default("vectis")   // nominal allocation column key (see lib/accounting.ts)
  reviewed   Boolean         @default(false)
  aiRun      Boolean         @default(false)      // has AI been run on this scan yet? (blank scans wait for a batch Run AI)
  aiNotes    String?                             // anything the AI flagged for attention
  splitGroupId String?                           // lines split from one invoice share this id (grouped together in the UI)
  currency       String?  @default("GBP")        // ISO currency shown on the invoice (GBP unless foreign)
  originalAmount Float?                           // gross in that foreign currency (e.g. 99 for €99) — stable key for reconciling foreign card charges
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([monthId])
}

// Learned categorisation memory — once a supplier is confirmed, reuse it next time.
model AccountingSupplierRule {
  id        String   @id @default(cuid())
  match     String   @unique          // normalised supplier text
  vatCode   Int
  column    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// The cards / accounts a document can be tagged to (managed by admins).
model AccountingCardholder {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// A bank/card statement uploaded for a month, to reconcile entered lines against.
model BankStatement {
  id           String          @id @default(cuid())
  monthId      String
  month        AccountingMonth @relation(fields: [monthId], references: [id], onDelete: Cascade)
  label        String          @default("")     // e.g. "OneCard May 2026"
  source       String          @default("SCAN") // SCAN (photo/PDF + AI) | CSV
  images       String[]        @default([])      // R2 keys of the statement pages (photo/PDF)
  createdAt    DateTime        @default(now())
  transactions BankTransaction[]

  @@index([monthId])
}

// One line on a statement. amount = the GBP actually charged (source of truth for cost).
model BankTransaction {
  id             String        @id @default(cuid())
  statementId    String
  statement      BankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)
  monthId        String                          // denormalised for month-wide queries
  postDate       DateTime?
  tranDate       DateTime?
  description    String        @default("")
  reference      String        @default("")      // "Your Ref" / bank reference
  amount         Float         @default(0)        // GBP settled amount
  currency       String        @default("GBP")    // original currency if a foreign charge
  originalAmount Float?                            // foreign amount (e.g. 99 for €99)
  feeAmount      Float?                            // non-sterling transaction fee if shown
  direction      String        @default("DEBIT")  // DEBIT | CREDIT (payment/refund)
  matchedDocIds  String[]      @default([])        // entered AccountingDocument id(s) this reconciles to (N = split invoice)
  ignored        Boolean       @default(false)     // marked as not needing a match (e.g. a card payment)
  createdAt      DateTime      @default(now())

  @@index([statementId])
  @@index([monthId])
}

// Singleton (id = "global") — stores the delegated OAuth tokens for the shared
// IT mailbox connection. Connected once by an admin via the sign-in flow.
model ITMailboxAuth {
  id           String   @id @default("global")
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  connectedBy  String?
  lastSyncAt   DateTime?
  updatedAt    DateTime @updatedAt
}
